# ===== Backend (Java/Spring Boot) =====

# Build output
target/
!**/src/main/**/target/
!**/src/test/**/target/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# Maven
.mvn/wrapper/maven-wrapper.jar
HELP.md

# Sensitive Spring configs (use *.example.properties instead)
BackEnd/src/main/resources/application.properties
BackEnd/src/main/resources/application-*.properties

# Logs
logs/
*.log

# ===== Frontend (Node.js/React/Vite) =====

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
*.local

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*


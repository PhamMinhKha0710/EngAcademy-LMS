{
  "name": "weblearnenglish",
  "version": "1.0.0",
  "description": "EnglishLearn là một nền tảng học tiếng Anh hiện đại, gamified dành cho học sinh phổ thông. Dự án kết hợp **bài học tương tác**, **nhiệm vụ hằng ngày**, **bài thi online**, **bảng xếp hạng** và **huy hiệu thành tích** để biến việc học thành một hành trình thú vị, có động lực rõ ràng.",
  "main": "index.js",
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-html-reporter": "^4.3.0",
    "puppeteer": "^24.40.0"
  },
  "jest": {
    "reporters": [
      "default",
      [
        "jest-html-reporter",
        {
          "pageTitle": "Báo cáo Kiểm thử E2E",
          "outputPath": "./e2e/Reports/test-report.html",
          "includeFailureMsg": true
        }
      ]
    ]
  },
  "scripts": {
    "test:e2e": "jest e2e/Tests/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PhamMinhKha0710/weblearnenglish.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/PhamMinhKha0710/weblearnenglish/issues"
  },
  "homepage": "https://github.com/PhamMinhKha0710/weblearnenglish#readme"
}

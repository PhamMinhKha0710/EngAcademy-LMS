            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lớp 10A1 - Tiếng Anh Nâng Cao\",\n  \"schoolId\": {{school_id}},\n  \"teacherId\": {{teacher_id}},\n  \"academicYear\": \"2025-2026\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Add Student to Class",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/classes/{{class_id}}/students/{{student_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        },
        {
          "name": "Get Classes by School",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/classes/school/{{school_id}}?page=0&size=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        }
      ]
    },
    {

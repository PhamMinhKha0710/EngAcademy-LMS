    {
      "name": "02 - Users",
      "item": [
        {
          "name": "Get Current User (Admin)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users/{{student_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        },
        {
          "name": "Get All Users (Paginated)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users?page=0&size=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/users/me?fullName=Nguyễn Văn An Updated",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        },
        {
          "name": "Add Coins to Student",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/users/{{student_id}}/coins?amount=100",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        }
      ]
    },
    {

            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Trường THPT Nguyễn Huệ - Quận 1\",\n  \"address\": \"123 Nguyễn Huệ, Phường Bến Nghé, Quận 1, TP.HCM\",\n  \"phone\": \"02838221234\",\n  \"email\": \"nguyenhue.q1@edu.vn\",\n  \"trialEndDate\": \"2026-06-01\",\n  \"isActive\": true\n}"

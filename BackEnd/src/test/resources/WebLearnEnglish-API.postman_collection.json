{
  "info": {
    "name": "EngAcademy-LMS API - Test Collection",
    "description": "Complete API test collection for EngAcademy-LMS platform.\n\nEnvironment Variables needed:\n- base_url: http://localhost:8080\n- admin_token: (auto-set after login)\n- teacher_token: (auto-set after login)\n- student_token: (auto-set after login)\n- school_token: (auto-set after login)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "admin_token", "value": "" },
    { "key": "teacher_token", "value": "" },
    { "key": "student_token", "value": "" },
    { "key": "school_token", "value": "" },
    { "key": "admin_id", "value": "" },
    { "key": "teacher_id", "value": "" },
    { "key": "student_id", "value": "" },
    { "key": "school_id", "value": "" },
    { "key": "class_id", "value": "" },
    { "key": "lesson_id", "value": "" },
    { "key": "question_id", "value": "" },
    { "key": "exam_id", "value": "" }
  ],
  "item": [
    {
      "name": "01 - Authentication",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/health"
          }
        },
        {
          "name": "Register Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.data) {",
                  "  pm.collectionVariables.set('admin_token', jsonData.data.accessToken);",
                  "  pm.collectionVariables.set('admin_id', jsonData.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],

            "body": {
              "mode": "raw",
              "raw": "{\n  \"lessonId\": {{lesson_id}},\n  \"questionType\": \"MULTIPLE_CHOICE\",\n  \"questionText\": \"What is the correct greeting in the morning?\",\n  \"points\": 10,\n  \"explanation\": \"Good morning is used before noon.\",\n  \"options\": [\n    {\"optionText\": \"Good morning\", \"isCorrect\": true},\n    {\"optionText\": \"Good night\", \"isCorrect\": false},\n    {\"optionText\": \"Goodbye\", \"isCorrect\": false},\n    {\"optionText\": \"See you later\", \"isCorrect\": false}\n  ]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "07 - Exams",
      "item": [
        {
          "name": "Create Exam",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.data) {",
                  "  pm.collectionVariables.set('exam_id', jsonData.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/exams?teacherId={{teacher_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacher_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Kiểm tra 15 phút - Unit 1\",\n  \"classId\": {{class_id}},\n  \"startTime\": \"2026-02-08T08:00:00\",\n  \"endTime\": \"2026-02-08T10:00:00\",\n  \"durationMinutes\": 15,\n  \"shuffleQuestions\": true,\n  \"shuffleAnswers\": true,\n  \"antiCheatEnabled\": false,\n  \"questionIds\": [{{question_id}}]\n}"
            }
          }
        },
        {
          "name": "Publish Exam",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/exams/{{exam_id}}/publish",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacher_token}}" }]
          }
        },
        {
          "name": "Close Exam",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/exams/{{exam_id}}/close",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacher_token}}" }]
          }
        },
        {
          "name": "Get Exam Results",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/exams/{{exam_id}}/results",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacher_token}}" }]
          }
        }
      ]
    },
    {
      "name": "08 - Progress",
      "item": [
        {
          "name": "Update Progress 50%",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/progress/user/{{student_id}}/lesson/{{lesson_id}}?percentage=50",
            "header": [{ "key": "Authorization", "value": "Bearer {{student_token}}" }]
          }
        },
        {
          "name": "Complete Lesson",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/progress/user/{{student_id}}/lesson/{{lesson_id}}/complete",
            "header": [{ "key": "Authorization", "value": "Bearer {{student_token}}" }]
          }
        },
        {
          "name": "Get User Stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/progress/user/{{student_id}}/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{student_token}}" }]
          }
        }
      ]
    },
    {
      "name": "09 - Vocabulary",
      "item": [
        {
          "name": "Get Vocab by Lesson",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/vocabulary/lesson/{{lesson_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{student_token}}" }]
          }
        },
        {
          "name": "Search Vocabulary",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/vocabulary/search?keyword=hello",
            "header": [{ "key": "Authorization", "value": "Bearer {{student_token}}" }]
          }
        },

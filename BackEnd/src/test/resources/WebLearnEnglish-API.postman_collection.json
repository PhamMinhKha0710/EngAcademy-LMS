              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Bài 1: Greeting and Introduction\",\n  \"contentHtml\": \"<h1>Greeting</h1><p>Learn basic greetings.</p>\",\n  \"audioUrl\": \"https://cdn.englishlearn.vn/audio/lesson1.mp3\",\n  \"difficultyLevel\": 1,\n  \"orderIndex\": 1,\n  \"isPublished\": true\n}"
            }
          }
        },
        {
          "name": "Get Published Lessons (Public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/lessons?published=true"
          }
        },

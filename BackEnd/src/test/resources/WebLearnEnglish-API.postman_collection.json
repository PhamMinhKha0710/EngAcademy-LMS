          "name": "Get Lesson by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/lessons/{{lesson_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{student_token}}" }]
          }
        }
      ]
    },
    {
      "name": "06 - Questions",
      "item": [
        {
          "name": "Create Multiple Choice Question",
